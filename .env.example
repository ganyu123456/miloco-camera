# AI 视频网关配置示例
# 复制为 .env 并填写实际值

# 服务器
HOST=0.0.0.0
PORT=8080
DEBUG=false

# QQ 邮件推送（填写后自动启用）
SMTP_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_qq@qq.com
SMTP_PASSWORD=your_authorization_code   # QQ 邮箱 -> 账户 -> 生成授权码
SMTP_TO=receiver@example.com           # 报警接收邮箱，多个用逗号分隔

# MediaMTX RTSP 服务器
# 下载地址: https://github.com/bluenviron/mediamtx/releases
MEDIAMTX_BIN=mediamtx     # 可以是绝对路径，如 /usr/local/bin/mediamtx
RTSP_HOST=localhost
RTSP_PORT=8554

# YOLO 模型
YOLO_MODEL=yolo11n.pt     # 首次运行自动下载
YOLO_CONFIDENCE=0.5

# 性能调优
FRAME_QUEUE_SIZE=2         # 每摄像头检测队列大小，越大延迟越高
ALERT_COOLDOWN=10          # 同类报警最小间隔（秒），避免刷屏
